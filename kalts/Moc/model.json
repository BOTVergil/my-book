{"Type": 0, "Bounds": {"Width": 12.7721109, "Height": 12.1297445, "CenterX": -0.0428739525, "CenterY": -2.94052863}, "FileReferences": {"Moc": "Moc.moc3", "Textures": ["Textures_.png", "Textures_.png", "Textures_.png"], "Physics": "Physics.json", "PhysicsV2": {"File": "Physics.json"}, "Motions": {"Start": [{"Name": "init", "PostCommand": "parameters lock ParamStrapDrag1 $strap_sp_newyear;parameters lock ParamSocksDrag $sock_sp_newyear;artmesh_opacities lock BackArt2,BackArt1,BackArt3 $bg_sp_newyear", "NextMtn": "Login", "VarFloats": [{"Name": "login_sp_newyear", "Type": 2, "Code": "init 0"}, {"Name": "leave_sp_newyear", "Type": 2, "Code": "init 1"}, {"Name": "sound_sp_newyear", "Type": 2, "Code": "init 1"}, {"Name": "standby_sp_newyear", "Type": 2, "Code": "init 1"}, {"Name": "bg_sp_newyear", "Type": 2, "Code": "init 1"}, {"Name": "strap_sp_newyear", "Type": 2, "Code": "init 0"}, {"Name": "sock_sp_newyear", "Type": 2, "Code": "init 0"}]}], "Case": [{"Name": "menu", "Text": "Menu", "Choices": [{"Text": "进场动画", "NextMtn": "SwitchLogin"}, {"Text": "闲置语音", "NextMtn": "SwitchLeave"}, {"Text": "声音", "NextMtn": "SwitchSound"}, {"Text": "背景", "NextMtn": "SwitchBG"}, {"Text": "切换模型", "NextMtn": "Case:change_menu"}]}, {"Name": "change_menu", "Text": "投影", "Choices": [{"Text": "默认投影", "NextMtn": "Change:p1"}, {"Text": "扩容投影", "NextMtn": "Change:p2"}, {"Text": "完型投影", "NextMtn": "Change:p3"}, {"Text": "绛夜沉醉", "NextMtn": "Change:anniversary"}, {"Text": "摩卡重奏", "NextMtn": "Change:carnival"}, {"Text": "循光意中人", "NextMtn": "Change:amusement"}, {"Text": "执锋·扩容投影", "NextMtn": "Change:sp_p2"}, {"Text": "执锋·狭境危情", "NextMtn": "Change:sp_bp"}, {"Text": "执锋·垂蓼沁韵", "NextMtn": "Change:sp_newyear"}]}, {"Name": "var_check", "Text": "login = {$vi_login_sp_newyear}{$br}souond = {$vi_sound_sp_newyear}{$br}leave = {$vi_leave_sp_newyear}{$br}background = {$vi_bg_sp_newyear}{$br}sock = {$vi_sock_sp_newyear}{$br}strap = {$vi_strap_sp_newyear}{$br}normal = {$vi_standby_sp_newyear}"}, {"Name": "silk_max", "Command": "parameters lock ParamSocksDrag 1", "VarFloats": [{"Name": "sock_sp_newyear", "Type": 1, "Code": "equal 0"}, {"Name": "sock_sp_newyear", "Type": 2, "Code": "assign 1"}]}, {"Name": "silk_reset", "Command": "parameters unlock ParamSocksDrag"}, {"Name": "shoe_max", "File": "Motions_Case_5.json", "Sound": "Motions_Case_5.wav", "SoundDelay": 5000, "Text": "诶，教授要帮我按摩吗？！那……就拜托您了……", "TextDelay": 5000, "VarFloats": [{"Name": "standby_sp_newyear", "Type": 2, "Code": "assign 3"}]}, {"Name": "body_touch_2nd", "Sound": "Motions_Case_6.wav", "SoundDelay": 5000, "SoundChannel": 1, "Text": "啊不！我不是那个意思……", "TextDelay": 5000}, {"Name": "touch_C1", "File": "Motions_Case_7.json", "Sound": "Motions_Case_7.wav", "Text": "呜……痛痛痛……", "VarFloats": [{"Name": "standby_sp_newyear", "Type": 2, "Code": "assign 1"}]}, {"Name": "strap_takeoff", "File": "Motions_Case_8.json", "Sound": "Motions_Case_8.wav", "Text": "唔……感觉有点奇怪呢……", "Command": "parameters lock ParamStrapDrag1 1", "VarFloats": [{"Name": "strap_sp_newyear", "Type": 1, "Code": "equal 0"}, {"Name": "strap_sp_newyear", "Type": 2, "Code": "assign 1"}]}, {"Name": "show login", "File": "Motions_Case_9.json", "Sound": "Motions_Case_9.wav", "Text": "诶？教、教授？！……那个，先不要看，我、我还在调整衣服……呀啊！……呜……好痛……"}], "Login": [{"Name": "login", "File": "Motions_Case_9.json", "Sound": "Motions_Case_9.wav", "Text": "诶？教、教授？！……那个，先不要看，我、我还在调整衣服……呀啊！……呜……好痛……", "Command": "parameters unlock ParamStrapDrag1;parameters unlock ParamSocksDrag;artmesh_opacities lock BackArt2,BackArt1,BackArt3 1", "PostCommand": "parameters lock ParamStrapDrag1 $strap_sp_newyear;parameters lock ParamSocksDrag $sock_sp_newyear;artmesh_opacities lock BackArt2,BackArt1,BackArt3 $bg_sp_newyear", "Priority": 9, "VarFloats": [{"Name": "login_sp_newyear", "Type": 1, "Code": "equal 1"}]}], "Tap": [{"Name": "sent", "MotionDuration": 1000}, {"Name": "rcvd", "Command": "start_mtn Case:menu", "PreMtn": "Tap:sent"}], "Leave300_1800_1800": [{"Name": "1", "Sound": "Motions_Leave300_1800_1800_0.wav", "Text": "从前需要我决断的事其实并不多，而现在真正承担起重要的工作后，我才感觉到，世界好像也变得更宽广了。从您的身后走到您的身边，原来看到的，是这样的视野啊。\r\r", "VarFloats": [{"Name": "leave_sp_newyear", "Type": 1, "Code": "equal 1"}]}, {"Name": "2", "Sound": "Motions_Leave300_1800_1800_1.wav", "Text": "对于无法忘怀的过去，我们总是被劝说放下执念，洒脱向前。我曾经也努力地与过去对抗，但从某一个时刻，也许是从拿起武器开始，我忽然意识到……惦念往昔与勇往直前，或许可以不是抉择，而是一体两面。\r\r", "VarFloats": [{"Name": "leave_sp_newyear", "Type": 1, "Code": "equal 1"}]}, {"Name": "3", "Sound": "Motions_Leave300_1800_1800_2.wav", "Text": "我已经不再迷惘了。为了一切无法再挽回的事，为了一切还能被拯救的事，让我们……一起走下去。\r\r", "VarFloats": [{"Name": "leave_sp_newyear", "Type": 1, "Code": "equal 1"}]}, {"Name": "4", "Sound": "Motions_Leave300_1800_1800_3.wav", "Text": "教授，在发呆吗？啊，是睡着了呀……好好休息吧。接下来的事，都放心交给我就好了。\r\r", "VarFloats": [{"Name": "leave_sp_newyear", "Type": 1, "Code": "equal 1"}]}, {"Name": "5", "Sound": "Motions_Leave300_1800_1800_4.wav", "Text": "唔？我正要去参与作战适应训练哦。从科研人员到前线作战，我也有了不少进步呢。要跟来检验一下成果吗，教授？\r\r", "VarFloats": [{"Name": "leave_sp_newyear", "Type": 1, "Code": "equal 1"}]}, {"Name": "6", "Sound": "Motions_Leave300_1800_1800_5.wav", "Text": "教授，您在吗？这是今天的工作文件，重要程度低的和日常报告我已经回复过了。其中一部分已经给出了预案，还有这里……嗯？相信我的决断吗？呵呵，谢谢您。那么，您就放心处理剩下的部分吧。这段时间以来我也成长了不少，只要能够帮上忙，一切都是值得的。如果还有什么我能做的，我都会尽力去做。\r\r", "VarFloats": [{"Name": "leave_sp_newyear", "Type": 1, "Code": "equal 1"}]}, {"Name": "7", "Sound": "Motions_Leave300_1800_1800_6.wav", "Command": "start_mtn LeaveAdd#1:7_1", "VarFloats": [{"Name": "leave_sp_newyear", "Type": 1, "Code": "equal 1"}]}, {"Name": "8", "Sound": "Motions_Leave300_1800_1800_7.wav", "Command": "start_mtn LeaveAdd#1:8_1", "VarFloats": [{"Name": "leave_sp_newyear", "Type": 1, "Code": "equal 1"}]}, {"Name": "9", "Sound": "Motions_Leave300_1800_1800_8.wav", "Command": "start_mtn LeaveAdd#1:9_1", "VarFloats": [{"Name": "leave_sp_newyear", "Type": 1, "Code": "equal 1"}]}, {"Name": "10", "Sound": "Motions_Leave300_1800_1800_9.wav", "Command": "start_mtn LeaveAdd#1:10_1", "VarFloats": [{"Name": "leave_sp_newyear", "Type": 1, "Code": "equal 1"}]}, {"Name": "11", "Sound": "Motions_Leave300_1800_1800_10.wav", "Text": "特地为了今天准备的衣服，不知道教授会喜欢吗……诶？教授？！您，您怎么这么早就来了……", "VarFloats": [{"Name": "leave_sp_newyear", "Type": 1, "Code": "equal 1"}]}], "LeaveAdd#1": [{"Name": "7_1", "Text": "今天的任务有点繁重，奖励自己多加几块方糖好了……八，九，十——咦，教授？您是什么时候回来的？被您看到有点幼稚的一面了呢。诶？这样也很可爱？教授又在取笑我了……既然如此，这杯咖啡就给您吧。", "TextDuration": 35000, "MotionDuration": 35000, "NextMtn": "LeaveAdd#1:7_2"}, {"Name": "7_2", "Text": "\r……您说像绿洲刚建立时的味道？呵呵呵，还真是生动的比喻。那时候啊，我总是习惯性地给自己增加工作，想着什么都让自己承担，其实也只是在用忙碌掩盖自己的不安吧。仿佛只要埋头于工作，就可以逃避那些无法面对的问题……但是，现在的我已经能更好地犒劳自己了。给，我为您新泡了一杯咖啡，尝尝这一杯怎么样呢？", "TextDelay": 1000, "TextDuration": 39000, "MotionDuration": 40000}, {"Name": "8_1", "Text": "教授，您在吗？这项安排我还有点拿不定主意，要拜托您帮我看看了……", "TextDuration": 10000, "MotionDuration": 10000, "NextMtn": "LeaveAdd#1:8_2"}, {"Name": "8_2", "Text": "啊，原来如此，的确这样处理更合适呢。虽然我最近也积累了不少经验，但果然还是教授最能切中事情的要害。呵呵，看来我要学的事还有很多——想到这点，就感到自己充满了动力呢。", "TextDelay": 1000, "TextDuration": 21000, "MotionDuration": 22000, "NextMtn": "LeaveAdd#1:8_3"}, {"Name": "8_3", "Text": "\r放心吧教授，我一点也没有感到辛苦哦。空闲下来的时候，每当我握紧那把刀，都能感到有温暖的力量在支持着我……我一定、一定会把这些事都处理好的。", "TextDelay": 1000, "TextDuration": 20000}, {"Name": "9_1", "Text": "您说未来的绿洲会是什么样子呢？对现在的我而言，绿洲已经不再是一个落脚之处，而是承载了无数珍贵回忆的容身之所。", "TextDuration": 16600, "MotionDuration": 16600, "NextMtn": "LeaveAdd#1:9_2"}, {"Name": "9_2", "Text": "最初上传到云端的时候，我对未来还一无所知。在迷茫之下，我失去了重要的人……就这样跌跌撞撞地前行着，直到再一次面对失去。找到方向的道路，真的很长很长，还好有教授一直指引着我。其实即使到了现在，关于教授您，以及整个云端，我都还有很多不曾明了的事。但我已经不会再陷入迷茫了，这是为了已经倒下的伙伴，以及仍在身边的伙伴。无论未来走向何方……", "TextDelay": 1000, "TextDuration": 53000, "MotionDuration": 54000}, {"Name": "10_1", "Text": "其实直到今天，我心智深处还会传来幻痛。人形也会有心痛的感觉吗？这种痛能带给我什么呢？它催促着我，不能再站在原地，一定要努力地向前走。握紧回忆，一步一步地走下去。教授，这样做……不对吗？", "TextDuration": 33500, "MotionDuration": 33500, "NextMtn": "LeaveAdd#1:10_2"}, {"Name": "10_2", "Text": "呵呵……真像是您会说的话呢。如果不愿意再展露软弱的自己，如果再浓的咖啡也不够有效——我可以再像这样单独对您诉说吗？即使只是静静地坐一会儿，心情也能奇迹般地平静很多，这是只有您能做到的。那么，我们就约定好了哦，教授。在这条漫长的道路上……以后也拜托您了。", "TextDelay": 1000, "TextDuration": 47000, "MotionDuration": 48000}], "SwitchLogin": [{"Name": "ON", "Text": "进场动画：开", "VarFloats": [{"Name": "login_sp_newyear", "Type": 1, "Code": "equal 0"}, {"Name": "login_sp_newyear", "Type": 2, "Code": "assign 1"}]}, {"Name": "OFF", "Text": "进场动画：关", "VarFloats": [{"Name": "login_sp_newyear", "Type": 1, "Code": "equal 1"}, {"Name": "login_sp_newyear", "Type": 2, "Code": "assign 0"}]}], "SwitchSound": [{"Name": "ON", "Text": "声音：开", "Command": "unmute_sound 0;unmute_sound 0;unmute_sound 0", "VarFloats": [{"Name": "sound_sp_newyear", "Type": 1, "Code": "equal 0"}, {"Name": "sound_sp_newyear", "Type": 2, "Code": "assign 1"}]}, {"Name": "OFF", "Text": "声音：关", "Command": "mute_sound 0;mute_sound 1;mute_sound 2", "VarFloats": [{"Name": "sound_sp_newyear", "Type": 1, "Code": "equal 1"}, {"Name": "sound_sp_newyear", "Type": 2, "Code": "assign 0"}]}], "SwitchLeave": [{"Name": "ON", "Text": "闲置语音：开", "VarFloats": [{"Name": "leave_sp_newyear", "Type": 1, "Code": "equal 0"}, {"Name": "leave_sp_newyear", "Type": 2, "Code": "assign 1"}]}, {"Name": "OFF", "Text": "闲置语音：关", "VarFloats": [{"Name": "leave_sp_newyear", "Type": 1, "Code": "equal 1"}, {"Name": "leave_sp_newyear", "Type": 2, "Code": "assign 0"}]}], "SwitchBG": [{"Name": "ON", "Text": "背景：开", "Command": "artmesh_opacities lock BackArt2,BackArt1,BackArt3 1", "VarFloats": [{"Name": "bg_sp_newyear", "Type": 1, "Code": "equal 0"}, {"Name": "bg_sp_newyear", "Type": 2, "Code": "assign 1"}]}, {"Name": "OFF", "Text": "背景：关", "Command": "artmesh_opacities lock BackArt2,BackArt1,BackArt3 0", "VarFloats": [{"Name": "bg_sp_newyear", "Type": 1, "Code": "equal 1"}, {"Name": "bg_sp_newyear", "Type": 2, "Code": "assign 0"}]}], "Idle": [{"Name": "normalA", "File": "Motions_Idle_0.json", "VarFloats": [{"Name": "standby_sp_newyear", "Type": 1, "Code": "equal 1"}]}, {"Name": "normalB", "File": "Motions_Idle_1.json", "VarFloats": [{"Name": "standby_sp_newyear", "Type": 1, "Code": "equal 2"}]}, {"Name": "normalC", "File": "Motions_Idle_2.json", "VarFloats": [{"Name": "standby_sp_newyear", "Type": 1, "Code": "equal 3"}]}], "Idle#1": [{"Name": "repeat", "File": "Motions_Idle#1_0.json"}], "Change": [{"Name": "p1", "Command": "change_cos model.json"}, {"Name": "p2", "Command": "change_cos model.json"}, {"Name": "p3", "Command": "change_cos model.json"}, {"Name": "amusement", "Command": "change_cos model.json"}, {"Name": "anniversary", "Command": "change_cos model.json"}, {"Name": "sp_p2", "Command": "change_cos model.json"}, {"Name": "sp_bp", "Command": "change_cos model.json"}, {"Name": "sp_newyear", "Command": "change_cos model.json"}, {"Name": "carnival", "Command": "change_cos model.json"}], "TapLegA": [{"Name": "touch_A1", "File": "Motions_TapLegA_0.json", "Sound": "Motions_TapLegA_0.wav", "Text": "教授……真是的……太过兴奋了哦……"}], "TapArmpit": [{"Name": "touch_A2", "File": "Motions_TapArmpit_0.json", "Sound": "Motions_TapArmpit_0.wav", "Text": "教授对这里感兴趣吗？再稍微靠近点……也是可以的哦……"}], "ShoesA": [{"Name": "touch_A3", "File": "Motions_ShoesA_0.json", "Sound": "Motions_ShoesA_0.wav", "Text": "啊，我的鞋子……可以拜托您帮我穿上吗？", "VarFloats": [{"Name": "standby_sp_newyear", "Type": 2, "Code": "assign 2"}]}], "TapHead": [{"Name": "touch_B1", "File": "Motions_TapHead_0.json", "Sound": "Motions_TapHead_0.wav", "Text": "教授，这不是猫耳哦，而是过滤杂波的信号处理器。不过，如果教授感兴趣的话……喵？……感觉怎么样呢？"}], "TapHipB": [{"Name": "touch_B2_takeoff", "File": "Motions_Case_8.json", "Sound": "Motions_Case_8.wav", "Text": "唔……感觉有点奇怪呢……", "Command": "parameters set ParamStrapDrag1 1", "VarFloats": [{"Name": "strap_sp_newyear", "Type": 1, "Code": "equal 0"}, {"Name": "strap_sp_newyear", "Type": 2, "Code": "assign 1"}], "Enabled": false}, {"Name": "touch_B2_takeon", "Command": "parameters unlock ParamStrapDrag1", "VarFloats": [{"Name": "strap_sp_newyear", "Type": 1, "Code": "equal 1"}, {"Name": "strap_sp_newyear", "Type": 2, "Code": "assign 0"}]}], "TapFoot": [{"Name": "touch_B3", "File": "Motions_TapFoot_0.json", "Sound": "Motions_TapFoot_0.wav", "Text": "呜……教授，可以还给我吗？有点凉飕飕的……"}], "TapSock": [{"Name": "sock_reset", "Command": "parameters unlock ParamSocksDrag", "VarFloats": [{"Name": "sock_sp_newyear", "Type": 1, "Code": "equal 1"}, {"Name": "sock_sp_newyear", "Type": 2, "Code": "assign 0"}]}], "TapBody": [{"Name": "touch_C3", "File": "Motions_TapBody_0.json", "Sound": "Motions_TapBody_0.wav", "Text": "教授，现在还是工作时间……", "Command": "start_mtn Case:body_touch_2nd"}], "TapHipC2": [{"Name": "touch_C2", "File": "Motions_TapHipC2_0.json", "Sound": "Motions_Case_7.wav", "Text": "呜……痛痛痛……", "VarFloats": [{"Name": "standby_sp_newyear", "Type": 2, "Code": "assign 1"}]}]}}, "Controllers": {"ParamHit": {"Items": [{"Name": "SocksDrag_X", "Id": "ParamSocksDrag", "HitArea": "Sock", "Axis": 0, "Factor": -0.01, "ReleaseType": 0, "MaxMtn": "Case:silk_max"}, {"Name": "SocksDrag_Y", "Id": "ParamSocksDrag", "HitArea": "Sock", "Axis": 1, "Factor": 0.01, "ReleaseType": 0, "MaxMtn": "Case:silk_max"}, {"Name": "ShoeDragA", "Id": "ParamShoeDrag1", "HitArea": "ShoesA", "Axis": 1, "Factor": 0.01, "ReleaseType": 0, "MaxMtn": "ShoesA"}, {"Name": "ShoeDragB", "Id": "ParamShoeDrag2", "HitArea": "ShoesB", "Axis": 1, "Factor": -0.01, "ReleaseType": 0, "MaxMtn": "Case:shoe_max"}, {"Name": "StrapDrag1", "Id": "ParamStrapDrag1", "HitArea": "HipB", "Axis": 0, "Factor": -0.02, "ReleaseType": 0, "MaxMtn": "Case:strap_takeoff"}, {"Name": "StrapDrag2", "Id": "ParamStrapDrag2", "HitArea": "HipC1", "Axis": 1, "Factor": 0.01, "ReleaseType": 0, "EndMtn": "Case:touch_C1"}], "Enabled": true}, "ParamLoop": {}, "KeyTrigger": {}, "ParamTrigger": {}, "AreaTrigger": {}, "HandTrigger": {}, "EyeBlink": {"MinInterval": 500, "MaxInterval": 6000, "Enabled": true}, "LipSync": {"Gain": 5.0, "Enabled": true}, "MouseTracking": {"SmoothTime": 0.447324276, "Enabled": true}, "AutoBreath": {"Enabled": true}, "ExtraMotion": {"Enabled": true}, "Accelerometer": {"Enabled": true}, "Microphone": {}, "Transform": {}, "FaceTracking": {"Enabled": true}, "HandTracking": {}, "ParamValue": {}, "PartOpacity": {}, "ArtmeshOpacity": {}, "ArtmeshColor": {}, "ArtmeshCulling": {"DefaultMode